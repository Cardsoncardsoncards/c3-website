<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} | Cards on Cards on Cards</title>
<meta name="description" content="{{ description }}">
<meta property="og:title" content="{{ title }} | Cards on Cards on Cards">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="https://cardsoncardsoncards.com.au/blog/{{ page.fileSlug }}.html">
<meta property="og:type" content="article">
<meta name="google-site-verification" content="4iyoNevmAtBUvb3Jqf3RPLWCB2dugngqoZWTKp2n7fI" />
<script async src="https://www.googletagmanager.com/gtag/js?id=G-WR68HPE92S"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-WR68HPE92S');</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/post.css">
<style>
/* NAV OVERRIDES FOR CONSISTENCY */
nav{background:rgba(10,12,20,.97) !important;backdrop-filter:blur(18px) !important}
.nav-logo{display:inline-flex !important;align-items:center !important;gap:9px !important;white-space:nowrap !important}
.nav-logo img{width:28px;height:28px;border-radius:6px;flex-shrink:0}
.nav-links{flex-wrap:nowrap !important;overflow-x:auto !important;scrollbar-width:none !important}
.nav-links::-webkit-scrollbar{display:none}
.nav-link{white-space:nowrap !important}
.nav-link--gold{color:#C9A84C !important;border-color:#7A621E !important;background:rgba(201,168,76,.06) !important}
.nav-link--gold:hover{background:rgba(201,168,76,.14) !important;border-color:#C9A84C !important}
.nav-link--purple{color:#9898FF !important;border-color:rgba(107,107,255,.3) !important;background:rgba(107,107,255,.06) !important}
.nav-link--purple:hover{background:rgba(107,107,255,.14) !important;border-color:#9898FF !important}
.nav-link--etsy{color:#F56400 !important;border-color:rgba(245,100,0,.32) !important;background:rgba(245,100,0,.05) !important}
.nav-link--etsy:hover{background:rgba(245,100,0,.14) !important;border-color:#F56400 !important}
/* CAROUSEL */
@keyframes pulse{0%,100%{opacity:0.4}50%{opacity:0.8}}
.carousel-section{margin:48px 0 32px;padding:32px;background:rgba(201,168,76,.04);border:1px solid rgba(201,168,76,.12);border-radius:14px}
.carousel-eyebrow{font-size:10px;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:#C9A84C;display:block;margin-bottom:6px}
.carousel-title{font-family:'Cinzel',serif;font-size:18px;font-weight:700;color:#F0F2FF;margin-bottom:16px}
.carousel-scroll{display:flex;gap:12px;overflow-x:auto;padding-bottom:12px;scrollbar-width:thin;scrollbar-color:#252840 transparent;scroll-snap-type:x mandatory}
.ebay-card{min-width:160px;max-width:160px;background:#161929;border:1px solid #252840;border-radius:12px;overflow:hidden;flex-shrink:0;scroll-snap-align:start;transition:all .22s;text-decoration:none;display:flex;flex-direction:column}
.ebay-card:hover{transform:translateY(-3px);border-color:rgba(201,168,76,.4);box-shadow:0 8px 24px rgba(0,0,0,.4)}
.ebay-card-img{width:100%;height:120px;object-fit:contain;background:#0d0f1a;padding:8px}
.ebay-card-img-ph{width:100%;height:120px;background:#0d0f1a;display:flex;align-items:center;justify-content:center;font-size:28px}
.ebay-card-body{padding:9px 11px;flex:1;display:flex;flex-direction:column;gap:4px}
.ebay-card-title{font-size:11px;color:#F0F2FF;line-height:1.35;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;flex:1}
.ebay-card-price{font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:#C9A84C;margin-top:4px}
.ebay-card-cta{font-size:10px;color:rgba(160,168,192,.5);margin-top:2px}
.skeleton{background:#161929;border:1px solid #252840;border-radius:12px;animation:pulse 1.5s ease-in-out infinite}
</style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/c3logo.png" alt="C3 Logo">
      Cards on Cards on Cards
    </a>
    <div class="nav-links">
      <a href="/shop.html" class="nav-link nav-link--gold">Shop</a>
      <a href="/blog" class="nav-link nav-link--active">Blog</a>
      <a href="/ev-calculator.html" class="nav-link nav-link--purple">EV Calc</a>
      <a href="/tracker.html" class="nav-link">Tracker</a>
      <a href="https://www.ebay.com.au/str/cardsoncardsoncards?mkcid=1&mkrid=705-53470-19255-0&siteid=15&campid=5339146789&customid=C3Store&toolid=10001&mkevt=1" target="_blank" rel="noopener" class="nav-link">eBay</a>
      <a href="https://blasdigital.etsy.com" target="_blank" rel="noopener" class="nav-link nav-link--etsy">D&amp;D Tools ↗</a>
      <a href="/contact.html" class="nav-link">Contact</a>
    </div>
  </div>
</nav>

<article class="wrap post-wrap">

  <header class="post-header">
    <div class="post-meta-top">
      <span class="post-tag {{ category | tagClass }}">{{ category | tagLabel }}</span>
      <time datetime="{{ date | dateISO }}" class="post-date">{{ date | dateDisplay }}</time>
    </div>
    <h1 class="post-h1">{{ title }}</h1>
    {% if description %}
    <p class="post-intro">{{ description }}</p>
    {% endif %}
    {% if affiliate_disclaimer %}
    <div class="disclaimer">This post contains affiliate links. If you buy through them, we may earn a small commission at no extra cost to you.</div>
    {% endif %}
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if cta_product_url %}
  <div class="post-cta">
    <h3>Ready to Buy?</h3>
    <p>All products mentioned are confirmed available on Amazon AU with current pricing.</p>
    <a href="{{ cta_product_url }}" target="_blank" rel="noopener sponsored" class="btn-gold">Check Price on Amazon AU →</a>
  </div>
  {% endif %}

  <!-- EBAY CAROUSEL -->
  <div class="carousel-section">
    <span class="carousel-eyebrow">Live from Our eBay Store</span>
    <h2 class="carousel-title">Top Listings Right Now</h2>
    <div id="ebay-carousel-post" class="carousel-scroll">
      <div class="skeleton" style="min-width:160px;height:215px;flex-shrink:0"></div>
      <div class="skeleton" style="min-width:160px;height:215px;flex-shrink:0;animation-delay:.1s"></div>
      <div class="skeleton" style="min-width:160px;height:215px;flex-shrink:0;animation-delay:.2s"></div>
      <div class="skeleton" style="min-width:160px;height:215px;flex-shrink:0;animation-delay:.3s"></div>
      <div class="skeleton" style="min-width:160px;height:215px;flex-shrink:0;animation-delay:.4s"></div>
    </div>
    <div style="text-align:right;margin-top:8px">
      <a href="https://www.ebay.com.au/str/cardsoncardsoncards?mkcid=1&mkrid=705-53470-19255-0&siteid=15&campid=5339146789&customid=C3PostCarousel&toolid=10001&mkevt=1" target="_blank" rel="noopener" style="font-size:12px;color:#C9A84C;text-decoration:none;opacity:.7">View all listings on eBay ↗</a>
    </div>
  </div>
  <!-- END EBAY CAROUSEL -->

  <div class="post-nav">
    <a href="/blog" class="post-back">← Back to Blog</a>
    <a href="/shop.html" class="btn-gold-sm">Browse TCG Shop →</a>
  </div>

</article>

<footer>
  <div class="wrap">
    <div class="footer-inner">
      <div class="footer-logo">Cards on Cards on Cards</div>
      <div class="footer-links">
        <a href="/" class="footer-link">Home</a>
        <a href="/shop.html" class="footer-link">Shop</a>
        <a href="/blog" class="footer-link">Blog</a>
        <a href="/ev-calculator.html" class="footer-link">EV Calc</a>
        <a href="/tracker.html" class="footer-link">Tracker</a>
        <a href="https://www.ebay.com.au/str/cardsoncardsoncards" target="_blank" rel="noopener" class="footer-link">eBay</a>
      </div>
      <div class="footer-copy">© 2026 Cards on Cards on Cards. All rights reserved.</div>
    </div>
  </div>
</footer>

<script>
document.addEventListener('click', function(e) {
  var el = e.target.closest('a[href]');
  if (!el) return;
  var href = el.getAttribute('href') || '';
  if (href.includes('docs.google.com/spreadsheets')) {
    gtag('event', 'tracker_open', {event_category: 'outbound', event_label: 'free_tracker'});
  } else if (href.includes('etsy.com/au/listing')) {
    gtag('event', 'etsy_tool_click', {event_category: 'outbound', event_label: el.textContent.trim().substring(0, 60)});
  } else if (href.includes('blasdigital.etsy.com')) {
    gtag('event', 'etsy_store_click', {event_category: 'outbound', event_label: 'blasdigital_store'});
  } else if (href.includes('ebay.com.au')) {
    gtag('event', 'ebay_store_click', {event_category: 'outbound', event_label: 'c3_ebay_store'});
  } else if (href.includes('amazon.com.au')) {
    gtag('event', 'amazon_click', {event_category: 'outbound', event_label: href.substring(0, 80)});
  }
});
(function(){
  async function loadCarousel(){
    try{
      const res = await fetch('/.netlify/functions/ebay-prices');
      const data = await res.json();
      const wrap = document.getElementById('ebay-carousel-post');
      if(!data.listings || data.listings.length === 0){
        wrap.innerHTML='<p style="color:#A0A8C0;font-size:13px;padding:20px 0">No listings found. <a href="https://www.ebay.com.au/str/cardsoncardsoncards" target="_blank" rel="noopener" style="color:#C9A84C">Visit our eBay store</a>.</p>';
        return;
      }
      wrap.innerHTML = data.listings.map(item=>`
        <a href="${item.url}" target="_blank" rel="noopener sponsored" class="ebay-card" onclick="gtag('event','ebay_carousel_click',{item_id:'${item.id}',item_price:${item.price}})">
          ${item.image ? `<img src="${item.image}" alt="${item.title.replace(/"/g,'&quot;')}" class="ebay-card-img" loading="lazy" onerror="this.style.display='none';this.nextSibling.style.display='flex'">` : ''}
          <div class="ebay-card-img-ph" style="${item.image ? 'display:none' : ''}">🃏</div>
          <div class="ebay-card-body">
            <div class="ebay-card-title">${item.title}</div>
            <div class="ebay-card-price">AU$${item.price.toFixed(2)}</div>
            <div class="ebay-card-cta">View on eBay ↗</div>
          </div>
        </a>`).join('');
    } catch(e){
      const wrap = document.getElementById('ebay-carousel-post');
      wrap.innerHTML='<p style="color:#A0A8C0;font-size:13px;padding:20px 0">Could not load listings. <a href="https://www.ebay.com.au/str/cardsoncardsoncards" target="_blank" rel="noopener" style="color:#C9A84C">Visit our eBay store directly</a>.</p>';
    }
  }
  loadCarousel();
})();
</script>

</body>
</html>
