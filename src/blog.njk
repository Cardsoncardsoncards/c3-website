.cat-btn[data-game="onepiece"].active{color:#D4001A;border-color:rgba(212,0,26,.5);background:rgba(212,0,26,.06)}
.cat-btn[data-game="yugioh"].active{color:#A855F7;border-color:rgba(168,85,247,.5);background:rgba(168,85,247,.06)}
