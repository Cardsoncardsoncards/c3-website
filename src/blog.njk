<script>
function applyFilters() {
  // Read active category
  const activeCat = document.querySelector('#catFilter .cat-btn.active')?.dataset.filter || 'all';
  const activeGame = document.querySelector('#gameFilter .cat-btn.active')?.dataset.game || 'all';

  // Update clicked button active state
  document.querySelectorAll('#catFilter .cat-btn').forEach(b => {
    if (event && b === event.target) {
      document.querySelectorAll('#catFilter .cat-btn').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
    }
  });
  document.querySelectorAll('#gameFilter .cat-btn').forEach(b => {
    if (event && b === event.target) {
      document.querySelectorAll('#gameFilter .cat-btn').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
    }
  });

  // Re-read after update
  const cat = document.querySelector('#catFilter .cat-btn.active')?.dataset.filter || 'all';
  const game = document.querySelector('#gameFilter .cat-btn.active')?.dataset.game || 'all';

  const guideCategories = ['buying-guides','value-and-worth','product-comparisons','selling-and-money'];
  let visibleCount = 0;

  document.querySelectorAll('#blogGrid .blog-card').forEach(card => {
    const c = card.dataset.category || '';
    const g = card.dataset.game || 'general';

    const catMatch = cat === 'all' || c === cat || (cat === 'buying-guides' && guideCategories.includes(c));
    const gameMatch = game === 'all' || g === game;

    if (catMatch && gameMatch) {
      card.style.display = 'flex';
      visibleCount++;
    } else {
      card.style.display = 'none';
    }
  });

  const noResults = document.getElementById('noResults');
  if (noResults) noResults.classList.toggle('visible', visibleCount === 0);
}

const obs = new IntersectionObserver(es => es.forEach(e => {
  if(e.isIntersecting){e.target.classList.add('in-view');obs.unobserve(e.target);}
}), {threshold:0.06});
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

