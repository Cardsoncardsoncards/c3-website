---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TCG Blog Australia | Buying Guides, Set Reviews & Game Guides | Cards on Cards on Cards</title>
<meta name="description" content="{{ description }}">
<meta property="og:title" content="TCG Blog | Cards on Cards on Cards">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="https://cardsoncardsoncards.com.au/blog">
<meta property="og:type" content="website">
<meta name="google-site-verification" content="4iyoNevmAtBUvb3Jqf3RPLWCB2dugngqoZWTKp2n7fI" />
<script async src="https://www.googletagmanager.com/gtag/js?id=G-WR68HPE92S"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-WR68HPE92S');</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--ink:#0A0C14;--deep:#111422;--card:#161929;--border:#252840;--gold:#C9A84C;--gold-lit:#E8C86A;--gold-dim:#7A621E;--silver:#A0A8C0;--white:#F0F2FF;--purple:#6B6BFF;--orange:#F56400}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--ink);color:var(--white);font-family:'DM Sans',sans-serif;font-size:16px;line-height:1.65;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;background-image:radial-gradient(ellipse 80% 40% at 50% -5%,rgba(201,168,76,.07) 0%,transparent 55%),repeating-linear-gradient(60deg,transparent,transparent 40px,rgba(255,255,255,.008) 40px,rgba(255,255,255,.008) 41px)}
.wrap{max-width:1100px;margin:0 auto;padding:0 24px;position:relative;z-index:1}
nav{position:sticky;top:0;z-index:100;background:rgba(10,12,20,.97);backdrop-filter:blur(18px);border-bottom:1px solid var(--border);padding:12px 0}
.nav-inner{display:flex;align-items:center;justify-content:space-between;max-width:1100px;margin:0 auto;padding:0 24px;gap:12px}
.nav-logo{display:inline-flex;align-items:center;gap:9px;font-family:'Cinzel',serif;font-size:12px;font-weight:700;letter-spacing:.12em;color:var(--gold);text-decoration:none;text-transform:uppercase;white-space:nowrap}
.nav-logo img{width:28px;height:28px;border-radius:6px;flex-shrink:0}
.nav-links{display:flex;gap:4px;flex-wrap:nowrap;overflow-x:auto;scrollbar-width:none}
.nav-links::-webkit-scrollbar{display:none}
.nav-link{display:inline-flex;align-items:center;gap:5px;padding:6px 10px;border-radius:6px;font-size:11px;font-weight:600;text-decoration:none;letter-spacing:.05em;text-transform:uppercase;transition:all .2s;border:1px solid var(--border);color:var(--silver);white-space:nowrap}
.nav-link:hover{color:var(--white);border-color:var(--silver);background:rgba(255,255,255,.04)}
.nav-link--gold{color:var(--gold);border-color:var(--gold-dim);background:rgba(201,168,76,.06)}
.nav-link--gold:hover{background:rgba(201,168,76,.14);border-color:var(--gold)}
.nav-link--active{color:var(--gold);border-color:var(--gold-dim);background:rgba(201,168,76,.06)}
.nav-link--purple{color:#9898FF;border-color:rgba(107,107,255,.3);background:rgba(107,107,255,.06)}
.nav-link--purple:hover{background:rgba(107,107,255,.14);border-color:#9898FF}
.nav-link--etsy{color:var(--orange);border-color:rgba(245,100,0,.32);background:rgba(245,100,0,.05)}
.nav-link--etsy:hover{background:rgba(245,100,0,.14);border-color:var(--orange)}
.page-hd{padding:56px 0 40px;text-align:center;position:relative;z-index:1}
.page-eyebrow{font-size:10px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:12px}
.page-h1{font-family:'Cinzel',serif;font-size:clamp(28px,5vw,52px);font-weight:900;color:var(--white);line-height:1.1;margin-bottom:12px}
.page-h1 .gold{color:var(--gold)}
.page-desc{font-size:14.5px;color:rgba(240,242,255,.5);max-width:500px;margin:0 auto}
.cat-filter{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin:28px 0 48px;padding:0 8px}
.cat-btn{padding:7px 16px;border-radius:100px;font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;border:1px solid var(--border);color:var(--silver);background:none;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif}
.cat-btn:hover{color:var(--white);border-color:var(--silver)}
.cat-btn.active{color:var(--gold);border-color:var(--gold-dim);background:rgba(201,168,76,.08)}
.gold-divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--gold-dim),var(--gold),var(--gold-dim),transparent);position:relative;z-index:1;margin:0}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:56px}
.blog-card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;text-decoration:none;display:flex;flex-direction:column;transition:all .22s}
.blog-card:hover{transform:translateY(-4px);border-color:rgba(201,168,76,.28);box-shadow:0 12px 36px rgba(0,0,0,.5)}
.blog-card-img{height:140px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#161929,#1a1f35);font-size:48px;position:relative;overflow:hidden}
.blog-card-img::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,var(--card) 100%)}
.blog-card-body{padding:18px 18px 20px;flex:1;display:flex;flex-direction:column;gap:8px}
.blog-card-meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.blog-card h3{font-family:'Cinzel',serif;font-size:14.5px;font-weight:700;color:var(--white);line-height:1.3;flex:1}
.blog-card p{font-size:12px;color:rgba(160,168,192,.6);line-height:1.5}
.read-more{display:inline-flex;align-items:center;gap:7px;margin-top:auto;padding-top:6px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gold)}
.post-tag{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:4px 10px;border-radius:3px}
.tag-guide{color:var(--gold);border:1px solid var(--gold-dim);background:rgba(201,168,76,.07)}
.tag-review{color:#4A9EFF;border:1px solid rgba(74,158,255,.3);background:rgba(74,158,255,.07)}
.tag-game{color:#4ABA7A;border:1px solid rgba(74,186,122,.3);background:rgba(74,186,122,.07)}
.tag-accessory{color:var(--silver);border:1px solid var(--border);background:rgba(160,168,192,.05)}
.post-date{font-size:11px;color:rgba(160,168,192,.4);letter-spacing:.05em}
.cta-strip{background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.18);border-radius:12px;padding:28px 32px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;margin:0 0 56px}
.cta-strip h3{font-family:'Cinzel',serif;font-size:17px;font-weight:700;color:var(--white);margin-bottom:5px}
.cta-strip p{font-size:13px;color:rgba(160,168,192,.65)}
.btn-gold{display:inline-flex;align-items:center;gap:7px;padding:11px 22px;border-radius:8px;font-size:12.5px;font-weight:600;font-family:'DM Sans',sans-serif;text-decoration:none;background:linear-gradient(135deg,var(--gold),#A8843A);color:#0A0C14;transition:all .2s}
.btn-gold:hover{background:linear-gradient(135deg,var(--gold-lit),var(--gold));transform:translateY(-1px)}
@keyframes pulse{0%,100%{opacity:0.4}50%{opacity:0.8}}
.carousel-section{margin-bottom:48px}
.section-eyebrow{font-size:10px;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:8px}
.section-title{font-family:'Cinzel',serif;font-size:clamp(18px,3vw,26px);font-weight:700;color:var(--white);margin-bottom:16px}
.carousel-scroll{display:flex;gap:12px;overflow-x:auto;padding-bottom:12px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;scroll-snap-type:x mandatory}
.ebay-card{min-width:175px;max-width:175px;background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;flex-shrink:0;scroll-snap-align:start;transition:all .22s;text-decoration:none;display:flex;flex-direction:column}
.ebay-card:hover{transform:translateY(-3px);border-color:rgba(201,168,76,.4);box-shadow:0 8px 24px rgba(0,0,0,.4)}
.ebay-card-img{width:100%;height:130px;object-fit:contain;background:#0d0f1a;padding:8px}
.ebay-card-img-ph{width:100%;height:130px;background:#0d0f1a;display:flex;align-items:center;justify-content:center;font-size:32px}
.ebay-card-body{padding:10px 12px;flex:1;display:flex;flex-direction:column;gap:4px}
.ebay-card-title{font-size:11px;color:var(--white);line-height:1.35;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;flex:1}
.ebay-card-price{font-family:'Cinzel',serif;font-size:14px;font-weight:700;color:var(--gold);margin-top:4px}
.ebay-card-cta{font-size:10px;color:rgba(160,168,192,.5);margin-top:2px}
.skeleton{background:var(--card);border:1px solid var(--border);border-radius:12px;animation:pulse 1.5s ease-in-out infinite}
footer{border-top:1px solid var(--border);padding:28px 0;position:relative;z-index:1}
.footer-inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.footer-logo{font-family:'Cinzel',serif;font-size:12px;font-weight:700;letter-spacing:.1em;color:var(--gold)}
.footer-copy{font-size:11px;color:rgba(160,168,192,.28)}
.footer-link{font-size:12px;color:rgba(160,168,192,.4);text-decoration:none;transition:color .2s}
.footer-link:hover{color:var(--silver)}
.reveal{opacity:0;transform:translateY(18px);transition:opacity .5s ease,transform .5s ease}
.reveal.in-view{opacity:1;transform:translateY(0)}
@media(max-width:820px){.blog-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:540px){.blog-grid{grid-template-columns:1fr}.cta-strip{flex-direction:column}.footer-inner{flex-direction:column;text-align:center}}
</style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/c3logo.png" alt="C3 Logo">
      Cards on Cards on Cards
    </a>
    <div class="nav-links">
      <a href="/shop.html" class="nav-link nav-link--gold">Shop</a>
      <a href="/blog" class="nav-link nav-link--active">Blog</a>
      <a href="/ev-calculator.html" class="nav-link nav-link--purple">EV Calc</a>
      <a href="/tracker.html" class="nav-link">Tracker</a>
      <a href="https://www.ebay.com.au/str/cardsoncardsoncards?mkcid=1&mkrid=705-53470-19255-0&siteid=15&campid=5339146789&customid=C3Store&toolid=10001&mkevt=1" target="_blank" rel="noopener" class="nav-link">eBay</a>
      <a href="https://blasdigital.etsy.com" target="_blank" rel="noopener" class="nav-link nav-link--etsy">D&amp;D Tools ↗</a>
      <a href="/contact.html" class="nav-link">Contact</a>
    </div>
  </div>
</nav>

<div class="wrap">
  <div class="page-hd">
    <p class="page-eyebrow">Cards on Cards on Cards</p>
    <h1 class="page-h1">TCG <span class="gold">Blog</span></h1>
    <p class="page-desc">Buying guides, set reviews, and game introductions built for Australian TCG players.</p>
  </div>

  <div class="gold-divider"></div>

  <div class="cat-filter">
    <button class="cat-btn active" data-filter="all" onclick="filterPosts('all')">All</button>
    <button class="cat-btn" data-filter="buying-guides" onclick="filterPosts('buying-guides')">Buying Guides</button>
    <button class="cat-btn" data-filter="beginner-guides" onclick="filterPosts('beginner-guides')">Game Guides</button>
    <button class="cat-btn" data-filter="accessories" onclick="filterPosts('accessories')">Accessories</button>
    <button class="cat-btn" data-filter="tools-and-trackers" onclick="filterPosts('tools-and-trackers')">Free Tools</button>
  </div>

  <div class="blog-grid" id="blogGrid">
    {%- set sortedPosts = collections.post | reverse -%}
    {%- for post in sortedPosts %}
    <a href="{{ post.url }}" class="blog-card reveal" data-category="{{ post.data.category }}">
      <div class="blog-card-img">{{ post.data.emoji | default("🃏") }}</div>
      <div class="blog-card-body">
        <div class="blog-card-meta">
          <span class="post-tag {{ post.data.category | tagClass }}">{{ post.data.category | tagLabel }}</span>
          <span class="post-date">{{ post.data.date | dateDisplay }}</span>
        </div>
        <h3>{{ post.data.title }}</h3>
        <p>{{ post.data.description }}</p>
        <span class="read-more">Read →</span>
      </div>
    </a>
    {%- endfor %}
  </div>

  <!-- EBAY CAROUSEL -->
  <div class="carousel-section">
    <span class="section-eyebrow">Live from Our eBay Store</span>
    <h2 class="section-title">Top Singles Right Now</h2>
    <div id="ebay-carousel-blog" class="carousel-scroll">
      <div class="skeleton" style="min-width:175px;height:230px;flex-shrink:0"></div>
      <div class="skeleton" style="min-width:175px;height:230px;flex-shrink:0;animation-delay:.1s"></div>
      <div class="skeleton" style="min-width:175px;height:230px;flex-shrink:0;animation-delay:.2s"></div>
      <div class="skeleton" style="min-width:175px;height:230px;flex-shrink:0;animation-delay:.3s"></div>
      <div class="skeleton" style="min-width:175px;height:230px;flex-shrink:0;animation-delay:.4s"></div>
    </div>
    <div style="text-align:right;margin-top:8px">
      <a href="https://www.ebay.com.au/str/cardsoncardsoncards?mkcid=1&mkrid=705-53470-19255-0&siteid=15&campid=5339146789&customid=C3Carousel&toolid=10001&mkevt=1" target="_blank" rel="noopener" style="font-size:12px;color:var(--gold);text-decoration:none;opacity:.7">View all listings on eBay ↗</a>
    </div>
  </div>
  <!-- END EBAY CAROUSEL -->

  <div class="cta-strip reveal">
    <div>
      <h3>Ready to Buy?</h3>
      <p>Every product mentioned in our guides is confirmed available on Amazon AU. Click through to check current pricing and stock.</p>
    </div>
    <a href="/shop.html" class="btn-gold">Browse TCG Shop →</a>
  </div>

</div>

<footer>
  <div class="wrap">
    <div class="footer-inner">
      <div class="footer-logo">Cards on Cards on Cards</div>
      <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center">
        <a href="/" class="footer-link">Home</a>
        <a href="/shop.html" class="footer-link">Shop</a>
        <a href="/ev-calculator.html" class="footer-link">EV Calc</a>
        <a href="/tracker.html" class="footer-link">Tracker</a>
        <a href="/contact.html" class="footer-link">Contact Us</a>
      </div>
      <div class="footer-copy">© 2026 Cards on Cards on Cards. All rights reserved.</div>
    </div>
  </div>
</footer>

<script>
function filterPosts(cat) {
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.cat-btn[data-filter="' + cat + '"]').classList.add('active');
  const guideCategories = ['buying-guides','value-and-worth','product-comparisons','selling-and-money'];
  document.querySelectorAll('#blogGrid .blog-card').forEach(card => {
    const c = card.dataset.category;
    const show = cat === 'all' || c === cat || (cat === 'buying-guides' && guideCategories.includes(c));
    card.style.display = show ? 'flex' : 'none';
  });
}
const obs = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting){e.target.classList.add('in-view');obs.unobserve(e.target);} }), {threshold:0.06});
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
(function(){
  async function loadCarousel(){
    try{
      const res = await fetch('/.netlify/functions/ebay-prices');
      const data = await res.json();
      const wrap = document.getElementById('ebay-carousel-blog');
      if(!data.listings || data.listings.length === 0){
        wrap.innerHTML='<p style="color:var(--silver);font-size:13px;padding:20px 0">No listings found. <a href="https://www.ebay.com.au/str/cardsoncardsoncards" target="_blank" rel="noopener" style="color:var(--gold)">Visit our eBay store</a>.</p>';
        return;
      }
      wrap.innerHTML = data.listings.map(item=>`
        <a href="${item.url}" target="_blank" rel="noopener sponsored" class="ebay-card" onclick="gtag('event','ebay_carousel_click',{item_id:'${item.id}',item_price:${item.price}})">
          ${item.image ? `<img src="${item.image}" alt="${item.title.replace(/"/g,'&quot;')}" class="ebay-card-img" loading="lazy" onerror="this.style.display='none';this.nextSibling.style.display='flex'">` : ''}
          <div class="ebay-card-img-ph" style="${item.image ? 'display:none' : ''}">🃏</div>
          <div class="ebay-card-body">
            <div class="ebay-card-title">${item.title}</div>
            <div class="ebay-card-price">AU$${item.price.toFixed(2)}</div>
            <div class="ebay-card-cta">View on eBay ↗</div>
          </div>
        </a>`).join('');
    } catch(e){
      const wrap = document.getElementById('ebay-carousel-blog');
      wrap.innerHTML='<p style="color:var(--silver);font-size:13px;padding:20px 0">Could not load listings. <a href="https://www.ebay.com.au/str/cardsoncardsoncards" target="_blank" rel="noopener" style="color:var(--gold)">Visit our eBay store directly</a>.</p>';
    }
  }
  loadCarousel();
})();
</script>

</body>
</html>
